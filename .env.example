# ==============================================================================
# Database Configuration
# ==============================================================================
POSTGRES_USER=your_database_user
POSTGRES_PASSWORD=your_database_password
POSTGRES_DB=your_database_name

# Note: In your actual .env for Docker, 'localhost' should be changed 
# to the name of your postgres service (e.g., 'postgres')
DATABASE_URL="postgresql://your_database_user:your_database_password@localhost:5432/your_database_name?schema=public"

# ==============================================================================
# Application Configuration
# ==============================================================================
PORT=3000

# ==============================================================================
# Security & Authentication (JWT)
# ==============================================================================
# Generate a secure random string for production
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_DAYS=7

# ==============================================================================
# Admin API Key (for protected admin routes)
# ==============================================================================
# Generate a secure random string for production
ADMIN_API_KEY=super-secret-admin-key
